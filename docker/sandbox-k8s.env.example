SANDBOX_MODE=k8s
SANDBOX_K8S_PROVISIONER_URL=http://sandbox-provisioner:8002
SANDBOX_K8S_REQUEST_TIMEOUT_SECONDS=30

SANDBOX_K8S_NAMESPACE=yuxi-sandbox
SANDBOX_RUNTIME_IMAGE=yuxi-sandbox-runtime:latest
SANDBOX_RUNTIME_PORT=8080
SANDBOX_K8S_READY_TIMEOUT_SECONDS=60
SANDBOX_K8S_SERVICE_TYPE=ClusterIP

SANDBOX_K8S_CPU_REQUEST=100m
SANDBOX_K8S_CPU_LIMIT=1000m
SANDBOX_K8S_MEMORY_REQUEST=256Mi
SANDBOX_K8S_MEMORY_LIMIT=256Mi
